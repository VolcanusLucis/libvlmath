{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "ninja",
      "description": "Ninja Multi-Config Generator",
      "hidden": true,
      "generator": "Ninja Multi-Config"
    },

    {
      "name": "linux-x64-gcc",
      "description": "Linux x64 GCC Toolchain",
      "toolchainFile": "${sourceDir}/toolchains/linux-x64-gcc.cmake",
      "inherits": ["base", "ninja"],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-x86-gcc",
      "description": "Linux x86 GCC Toolchain",
      "toolchainFile": "${sourceDir}/toolchains/linux-x86-gcc.cmake",
      "inherits": ["base", "ninja"],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "win-x64-mingw64",
      "description": "Windows x64 MinGW64 Toolchain",
      "toolchainFile": "${sourceDir}/toolchains/win-x64-mingw64.cmake",
      "inherits": ["base", "ninja"]
    },
    {
      "name": "win-x86-mingw64",
      "description": "Windows x86 MinGW64 Toolchain",
      "toolchainFile": "${sourceDir}/toolchains/win-x86-mingw64.cmake",
      "inherits": ["base", "ninja"]
    }
  ],
  
  "buildPresets": [
    {
      "name": "debug",
      "configuration": "Debug",
      "hidden": true
    },
    {
      "name": "release",
      "configuration": "Release",
      "hidden": true
    },

    {
      "name": "linux-x64-gcc",
      "configurePreset": "linux-x64-gcc",
      "hidden": true
    },
    {
      "name": "linux-x86-gcc",
      "configurePreset": "linux-x86-gcc",
      "hidden": true
    },
    {
      "name": "win-x64-mingw64",
      "configurePreset": "win-x64-mingw64",
      "hidden": true
    },
    {
      "name": "win-x86-mingw64",
      "configurePreset": "win-x86-mingw64",
      "hidden": true
    },


    {
      "name": "linux-x64-gcc-debug",
      "displayName": "Linux x64 GCC - Debug",
      "inherits": ["linux-x64-gcc", "debug"]
    },
    {
      "name": "linux-x64-gcc-release",
      "displayName": "Linux x64 GCC - Release",
      "inherits": ["linux-x64-gcc", "release"]
    },
    {
      "name": "linux-x86-gcc-debug",
      "displayName": "Linux x86 GCC - Debug",
      "inherits": ["linux-x86-gcc", "debug"]
    },
    {
      "name": "linux-x86-gcc-release",
      "displayName": "Linux x86 GCC - Release",
      "inherits": ["linux-x86-gcc", "release"]
    },

    {
      "name": "win-x64-mingw64-debug",
      "displayName": "Windows x64 MinGW64 - Debug",
      "inherits": ["win-x64-mingw64", "debug"]
    },
    {
      "name": "win-x64-mingw64-release",
      "displayName": "Windows x64 MinGW64 - Release",
      "inherits": ["win-x64-mingw64", "release"]
    },
    {
      "name": "win-x86-mingw64-debug",
      "displayName": "Windows x86 MinGW64 - Debug",
      "inherits": ["win-x86-mingw64", "debug"]
    },
    {
      "name": "win-x86-mingw64-release",
      "displayName": "Windows x86 MinGW64 - Release",
      "inherits": ["win-x86-mingw64", "release"]
    }
  ]
}